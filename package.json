{
  "name": "clavix",
  "version": "0.2.8",
  "description": "Client desktop moderne pour Vaultwarden/Bitwarden",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "paraglide": "paraglide-js compile --project ./project.inlang --outdir ./src/lib/paraglide",
    "check": "pnpm run paraglide && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "pnpm run paraglide && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "test": "pnpm run paraglide && vitest run",
    "test:watch": "pnpm run paraglide && vitest",
    "test:e2e": "wdio run tests/e2e/wdio.conf.mjs",
    "tauri": "tauri"
  },
  "license": "GPL-3.0-or-later",
  "dependencies": {
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-clipboard-manager": "^2.3.2",
    "@tauri-apps/plugin-opener": "^2"
  },
  "devDependencies": {
    "@fontsource/atkinson-hyperlegible": "^5.2.8",
    "@fontsource/inter": "^5.2.8",
    "@inlang/paraglide-js": "^2.18.1",
    "@sveltejs/adapter-static": "^3.0.6",
    "@sveltejs/kit": "^2.60.1",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tauri-apps/cli": "^2.11.2",
    "@types/node": "^25.9.1",
    "@wdio/cli": "^7.36.0",
    "@wdio/local-runner": "^7.36.0",
    "@wdio/mocha-framework": "^7.36.0",
    "@wdio/spec-reporter": "^7.36.0",
    "jsqr": "^1.4.0",
    "svelte": "^5.55.7",
    "svelte-check": "^4.4.8",
    "typescript": "~5.6.2",
    "vite": "^8.0.14",
    "vitest": "^4.1.5"
  },
  "pnpm": {
    "overrides": {
      "cookie@<0.7.0": "^0.7.0",
      "esbuild@<0.25.0": "^0.25.0",
      "kysely@<0.28.17": "^0.28.17",
      "minimatch@<3.1.3": "^3.1.3",
      "serialize-javascript@<7.0.5": "^7.0.5",
      "tar-fs@>=2.0.0 <2.1.4": "^2.1.4",
      "tmp@<0.2.4": "^0.2.4",
      "uuid@<14.0.0": "^14.0.0",
      "ws@>=8.0.0 <8.17.1": "^8.17.1"
    }
  }
}
